    "mobile-390": { "width": 390, "height": 844, "coverage": "full" }
  },
  "interactionPolicies": {
    "primaryAction": {
      "selector": "[data-primary-action]",
      "allowedPolicies": ["exactly-one", "at-most-one", "none"]
    },
    "overflow": {
      "documentTolerancePx": 1,
      "hideDocumentOverflowAllowed": false,
      "clickableIntersectionRequired": true,
      "stickyContentGapPx": 16
    },
    "keyboard": {
      "focusVisibleRequired": true,
      "focusReturnRequired": true,
      "activationKeys": ["Enter", "Space"],
      "drawerCloseKey": "Escape",
      "skipLinkRequired": true
    },
    "reducedMotion": {
      "mediaQuery": "(prefers-reduced-motion: reduce)",
      "requiredSelector": "[data-motion]",
      "allowedValues": ["paused", "reduced"],
      "nonEssentialMotion": "disabled"
    }
  },
  "capturePolicy": {
    "fileNameTemplate": "<surface>--<state>--<actor>--<viewport>.png",
    "requiredReportFields": [
      "contractVersion", "setup", "screenshotSha256", "actualUrl", "actor", "state", "revision", "snapshotVersion"
    ],
    "stabilityWaits": ["fonts", "images", "critical-api", "state-selector", "motion-paused"]
  },
