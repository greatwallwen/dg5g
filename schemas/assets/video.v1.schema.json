{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dgbook.asset.video.v1",
  "title": "DGBook Video Asset",
  "type": "object",
  "required": ["schema", "id", "durationMs", "canvas", "tracks"],
  "properties": {
    "schema": { "const": "dgbook.asset.video/v1" },
    "id": { "type": "string" },
    "durationMs": { "type": "number", "minimum": 1 },
    "canvas": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      }
    },
    "tracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "clips"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["visual", "audio", "subtitle"] },
          "clips": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "src", "startMs", "durationMs"],
              "properties": {
                "id": { "type": "string" },
                "src": { "type": "string" },
                "startMs": { "type": "number", "minimum": 0 },
                "durationMs": { "type": "number", "minimum": 1 },
                "transition": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "subtitles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["startMs", "endMs", "text"],
        "properties": {
          "startMs": { "type": "number", "minimum": 0 },
          "endMs": { "type": "number", "minimum": 0 },
          "text": { "type": "string" }
        }
      }
    }
  }
}
