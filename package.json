{
  "name": "dgbook",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.20.2"
  },
  "description": "DGBook 数字化教材生产工具链",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm web:dev",
    "build": "pnpm web:build",
    "typecheck": "pnpm web:typecheck",
    "qa:web": "pnpm web:check-structure && pnpm audit:dark-engineering-ui && pnpm audit:capability-map && pnpm web:test:unit && pnpm web:typecheck && pnpm web:build",
    "qa:gates": "pnpm qa:web && pnpm audit:content && pnpm audit:image2-reference && pnpm test:image2-route-contract && pnpm test:image2-layout && pnpm qa:web:runtime && pnpm --filter @dgbook/widgets typecheck && pnpm --filter @dgbook/animation typecheck",
    "qa:demo-live": "pnpm qa:gates && pnpm audit:web:remote:protocol && pnpm audit:web:remote",
    "split": "node scripts/split-master.mjs",
    "import:5g": "uv run --python 3.12 scripts/import-5g-docx.py",
    "validate": "node scripts/validate-projects.mjs",
    "typecheck:generation": "pnpm --filter @dgbook/generation typecheck",
    "typecheck:animation": "pnpm --filter @dgbook/animation typecheck",
    "dgbook": "node scripts/dgbook.mjs",
    "dgbook:init": "node scripts/dgbook.mjs init content/new-book",
    "dgbook:import-md": "node scripts/dgbook.mjs import-markdown",
    "dgbook:validate-md": "node scripts/dgbook.mjs validate-markdown",
    "dgbook:validate-dsl": "node scripts/dgbook.mjs validate-dsl",
    "dgbook:tts": "node scripts/dgbook.mjs tts-build",
    "tts:setup": "node scripts/tts-local.mjs setup",
    "tts:start": "node scripts/tts-local.mjs start",
    "tts:health": "node scripts/tts-local.mjs health",
    "tts:sample": "node scripts/tts-local.mjs sample",
    "tts:sample:qwen": "node scripts/tts-local.mjs sample --provider qwen",
    "tts:clone": "node scripts/tts-local.mjs clone",
    "tts:build": "node scripts/tts-local.mjs build",
    "tts:build:qwen": "node scripts/tts-local.mjs build --provider qwen",
    "validate:animation": "node scripts/validate-animation-benchmarks.mjs --all",
    "audit:animation-layout": "node scripts/audit-animation-layout.mjs",
    "audit:animation-story": "node scripts/audit-animation-story-quality.mjs",
    "audit:animation-screenshots": "node scripts/audit-animation-screenshots.mjs --projects P01,P02,P03,P04,P05,P06,P07,P08,P09,P10,P11,P12,P13,P14,P15,P16,P17,P18",
    "audit:playback-runtime": "node scripts/audit-playback-runtime.mjs",
    "audit:content": "node scripts/audit-content-structure.mjs",
    "audit:textbook-boundaries": "node scripts/audit-textbook-boundaries.mjs",
    "audit:textbook-manifests": "node scripts/audit-textbook-manifests.mjs",
    "audit:semantic": "node scripts/audit-5g-semantic-quality.mjs",
    "audit:semantic-gates": "node scripts/audit-semantic-gates.mjs",
    "audit:5g-completion": "node scripts/audit-5g-completion.mjs",
    "audit:image2-reference": "node scripts/audit-image2-reference.mjs",
    "test:image2-route-contract": "node --test scripts/image2-route-contract.test.mjs",
    "test:image2-layout": "node --test scripts/audit-image2-layout.test.mjs",
    "capture:image2-implementation": "node scripts/capture-image2-implementation.mjs",
    "audit:image2-layout": "node scripts/audit-image2-layout.mjs",
    "audit:p1-complete-journey": "node scripts/audit-p1-complete-journey.mjs",
    "test:deploy-web-source-contract": "node --test scripts/deploy-web-source-contract.test.mjs",
    "audit:dark-engineering-ui": "node scripts/audit-dark-engineering-ui.mjs",
    "audit:5g-quality": "node scripts/audit-5g-quality.mjs",
    "audit:homepage": "node scripts/audit-homepage-runtime.mjs",
    "audit:capability-map": "node scripts/audit-capability-map-v2.mjs",
    "audit:manim-uniqueness": "node scripts/audit-manim-uniqueness.mjs",
    "audit:professional-assets": "node scripts/audit-animation-professional-assets.mjs",
    "audit:edugame-assets": "node scripts/audit-edugame-assets.mjs",
    "audit:edugame-challenge": "node scripts/audit-edugame-challenge.mjs",
    "audit:edugame-runtime": "node scripts/audit-edugame-runtime.mjs",
    "audit:edugame-kit": "node scripts/audit-edugame-kit.mjs",
    "codegraph:read": "node scripts/codegraph-read.mjs",
    "media:health": "node scripts/media-runtime.mjs health",
    "media:setup:manim": "node scripts/media-runtime.mjs setup-manim",
    "manim:build": "node scripts/manim-build.mjs",
    "validate:media-assets": "node scripts/validate-media-assets.mjs",
    "validate:ralph-loop": "node scripts/ralph-loop-check.mjs",
    "validate:architecture": "node scripts/validate-architecture-contracts.mjs",
    "check:file-sizes": "node scripts/check-file-sizes.mjs 800",
    "check:text": "node scripts/check-text-quality.mjs",
    "web:dev": "pnpm --filter @dgbook/web dev",
    "web:build": "pnpm --filter @dgbook/web build",
    "web:typecheck": "pnpm --filter @dgbook/web typecheck",
    "web:test:unit": "node scripts/run-web-unit-tests.mjs",
    "classroom-helper:start": "node scripts/classroom-helper.mjs",
    "web:qa": "pnpm --filter @dgbook/web qa",
    "qa:web:runtime": "node scripts/run-web-runtime-audits.mjs",
    "web:check-structure": "node scripts/check-web-structure.mjs",
    "audit:web-runtime": "node scripts/audit-web-runtime.mjs",
    "audit:web:remote:protocol": "node scripts/audit-live-classroom-protocol.mjs",
    "audit:web:remote": "node scripts/audit-web-remote.mjs",
    "audit:class-session-sync": "node scripts/audit-class-session-sync.mjs",
    "audit:class-session-cross-context": "node scripts/audit-class-session-cross-context.mjs",
    "audit:p1-three-terminal-consistency": "node scripts/audit-p1-three-terminal-consistency.mjs",
    "audit:self-study-closure": "node scripts/audit-self-study-closure.mjs",
    "audit:p0-phase1-truth-closure": "node scripts/audit-p0-phase1-truth-closure.mjs",
    "audit:active-workspace": "node scripts/audit-active-workspace.mjs",
    "audit:legacy-runtime-closure": "node scripts/audit-legacy-runtime-closure.mjs",
    "test:workspace-cleanup": "node --test scripts/active-workspace-policy.test.mjs scripts/release-evidence-index.test.mjs scripts/audit-active-workspace.test.mjs scripts/cleanup-runtime-artifacts.test.mjs",
    "test:legacy-runtime-closure": "node --test scripts/audit-legacy-runtime-closure.test.mjs",
    "test:web-media-cutover": "node --test scripts/web-media-cutover-plan.test.mjs scripts/audit-web-media-cutover.test.mjs scripts/cutover-web-media.test.mjs scripts/quarantine-web-media-rollback.test.mjs scripts/audit-web-media-runtime.test.mjs scripts/web-source-release-policy.test.mjs scripts/web-media-eol-policy.test.mjs scripts/prepare-web-source-release.test.mjs scripts/prepare-web-release.test.mjs",
    "audit:web-media-cutover": "node scripts/audit-web-media-cutover.mjs",
    "cutover:web-media": "node scripts/cutover-web-media.mjs",
    "deploy:web": "node scripts/prepare-web-release.mjs",
    "deploy:web:build-ready": "node scripts/prepare-web-release.mjs --build",
    "deploy:web:ssh": "node scripts/deploy-web-ssh.mjs",
    "deploy:web:source": "node scripts/prepare-web-source-release.mjs",
    "deploy:web:source:ssh": "node scripts/deploy-web-source-ssh.mjs",
    "deploy:web:source:paramiko": "python scripts/deploy-web-source-paramiko.py",
    "deploy:web:source:ready": "node scripts/release-web-source.mjs"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
