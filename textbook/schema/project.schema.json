{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dgbook/project.schema.json",
  "title": "DGBook 项目页 Frontmatter Schema",
  "type": "object",
  "required": ["project_id", "title", "chapter", "unit", "icon"],
  "additionalProperties": true,
  "properties": {
    "project_id":     { "type": "string", "pattern": "^P[0-9]{2}$" },
    "title":          { "type": "string", "minLength": 1 },
    "chapter":        { "type": "string", "pattern": "^ch[1-8]$" },
    "unit":           { "type": "string", "pattern": "^u[1-9]$" },
    "icon":           { "type": "string", "minLength": 2 },
    "chip":           { "type": "string", "default": "5G网优" },
    "peripherals":    {
      "type": "array",
      "items": { "type": "string" },
      "description": "Legacy field kept for older embedded-course pages; 5G pages normally use threads/widgets/playbackScenes."
    },
    "threads":        { "type": "array",  "items": { "type": "string" } },
    "estimatedPages": { "type": "integer", "minimum": 1, "maximum": 80 },
    "masterLines":    {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 4,
      "description": "Source trace line ranges from the importer when available."
    },
    "widgets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "已发布 widget 实例 ID 列表,site 据此 lazy 渲染"
    },
    "status": {
      "type": "string",
      "enum": ["outline", "draft", "review", "published"],
      "default": "outline"
    },
    "playbackScenes": {
      "type": "array",
      "description": "Single-direction teaching playback scenes generated by the importer or generation pipeline."
    }
  }
}
