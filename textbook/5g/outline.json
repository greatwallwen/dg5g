{
  "$schema": "./schema/outline.schema.json",
  "title": "5G网络优化（高级）",
  "subtitle": "DGBook · 5G 网络优化数字化教材",
  "audience": "职业院校通信技术、移动通信和网络优化方向学习者",
  "totalHours": 64,
  "weeks": 16,
  "prerequisites": [
    "移动通信基础",
    "无线网络基础"
  ],
  "competencies": [
    "5G网络信息采集能力",
    "路测与数据分析能力",
    "网络参数检查与优化能力",
    "信令分析与问题定位能力"
  ],
  "chapters": [
    {
      "id": "ch1",
      "no": 1,
      "title": "5G网络信息采集",
      "icon": "radio-tower",
      "goal": "5G网络信息采集，是5G网络规划和优化工作必要的前置准备环节，是网络规划和优化的基础，本项目详细介绍了5G基站的室内环境信息采集、室外环境信息采集和客户投诉信息采集的过程和反馈。通过本项目的学习，可以明确网络规划和优化工作前需要采集的相关基础信息，掌握5G基站室内、室外环境和客户投诉等相关信息的收集方法和要点。",
      "units": [
        "u1"
      ]
    },
    {
      "id": "ch2",
      "no": 2,
      "title": "5G网络测试",
      "icon": "route",
      "goal": "网络测试是反应网络中存在问题的最基本手段，该项目主要介绍DT（路测DriverTest）和CQT（CallQualityTest即呼叫质量测试）的测试流程以及测试中常见的异常问题处理思路，通过完成本项目学习后能够掌握无线网络测试流程、测试软件及相关工具的使用以及后台测试数据分析，可以独立完成网络测试环节的工作。",
      "units": [
        "u2"
      ]
    },
    {
      "id": "ch3",
      "no": 3,
      "title": "5G网络信息管理",
      "icon": "server-cog",
      "goal": "5G网络信息管理是对于网络运行状态、网络性能指标、网络参数检查和配置的重要管理系统，本项目通过介绍5G网络告警及性能的监控方法，以及与5G网络优化相关的无线接入网参数、传输网参数和核心网参数的检查和设置，使得学员完成本项目学习后，掌握5G网络运行监控，网络参数检查和网络参数调整等技能。",
      "units": [
        "u3"
      ]
    },
    {
      "id": "ch4",
      "no": 4,
      "title": "5G端到端网络优化",
      "icon": "activity",
      "goal": "本项目介绍5G端到端网络优化的工作内容，学习内容包括了端到端优化方案实施，端到端优化结果验证，端到端优化报告输出。通过本项目的学习，能够掌握5G端到端网络优化的基本技能。",
      "units": [
        "u4"
      ]
    },
    {
      "id": "ch5",
      "no": 5,
      "title": "5G全网性能提升",
      "icon": "chart-line",
      "goal": "5G基站入网验收后就进入到日常运维阶段，主要对全网性能指标进行优化和提升，保障5G网络的用户感知。本项目学习5G网络性能指标的定义、采集方法，性能指标分析、制定性能指标提升方案，并对方案进行验证。学习结束后应具备：",
      "units": [
        "u5"
      ]
    },
    {
      "id": "ch6",
      "no": 6,
      "title": "5G信令分析",
      "icon": "workflow",
      "goal": "由于移动网络无线环境的复杂性,在5G网络优化中,问题定位具有一定的模糊性和不确定性,而信令分析由于其数据采集的充分性、数据分析的全面性和精确性,对提高问题定位的准确性有很大作用。通过本项目的学习，能够熟练掌握5G空口常见的注册流程、鉴权加密流程、PDU会话建立、重配置和重建立等信令类型，结合无线参数变化，分析网络接入问题，移动性问题，掉线问题等，并最终提出...",
      "units": [
        "u6"
      ]
    }
  ],
