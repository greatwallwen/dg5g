    "storyboard": {
      "schema": "lesson-storyboard/v1",
      "learningGoal": "学完后能用统一台账描述机房、BBU/AAU-RRU、端口、传输、电源、接地和温控关系，并判断资料是否可追溯。",
      "summary": "本节把室内站点采集讲成一条资源链：从机房和机柜定位，到设备拓扑、配套条件和影像索引，最终支撑规划、排障和优化复核。",
      "knowledgeUnits": [
        {
          "id": "P01-ku-01",
          "title": "室内资源边界",
          "kind": "concept",
          "shortText": "机房、机柜、主设备和配套资源先建台账。",
          "narrationText": "室内信息采集要先锁定资源边界：机房位置、机柜编号、BBU、AAU/RRU、电源、传输、接地和温控共同决定站点可用性。"
        },
        {
          "id": "P01-ku-02",
          "title": "设备拓扑",
          "kind": "concept",
          "shortText": "主设备、承载和走线关系要可追溯。",
          "narrationText": "设备记录不止列型号，还要说明端口、光纤、电源线和传输承载的连接关系，后续定位才知道从哪一段查起。"
        },
        {
          "id": "P01-ku-03",
          "title": "运行条件",
          "kind": "criteria",
          "shortText": "供电、接地、温控和传输共同影响站点稳定性。",
          "narrationText": "运行条件要和主设备一起记录：供电容量、接地状态、空调能力和传输可用性会直接影响告警、业务稳定和后续排障。"
        },
        {
          "id": "P01-ku-04",
          "title": "现场证据",
          "kind": "evidence",
          "shortText": "机柜、端口和走线路径应对应同一设备。",
          "narrationText": "现场证据要能对应机柜、端口和走线路径，表单字段要能追溯到实体对象，避免后续复核时只剩孤立图片。"
        },
        {
          "id": "P01-ku-05",
          "title": "关系校验",
          "kind": "practice",
          "shortText": "用设备到配套的链路校验采集完整性。",
          "narrationText": "完整性校验关注主设备、传输、电源、接地和温控是否形成闭合关系，缺一段都会影响后续规划、测试或故障定位。"
        },
        {
          "id": "P01-ku-06",
          "title": "资料归档",
          "kind": "review",
          "shortText": "形成可复核的室内站点基础资料。",
          "narrationText": "室内资料归档要保留对象、位置、连接、运行条件和证据索引，为路测、参数核查和优化判断提供共同底座。"
        }
      ],
      "reviewSummary": "复盘时检查资源对象、连接关系、运行条件和照片索引是否指向同一站点实体，缺口要回填到台账，而不是留在截图说明里。"
    }
