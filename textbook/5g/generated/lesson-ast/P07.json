    "storyboard": {
      "schema": "lesson-storyboard/v1",
      "learningGoal": "学完后能按对象层级筛告警、查性能、核配置，并明确查询、修改、派单和回退的权限边界。",
      "summary": "本节把网管操作看成对象管理模型：从 ManagedElement、小区、告警、PM、CM 到权限审计，形成可追踪的运维闭环。",
      "knowledgeUnits": [
        {
          "id": "P07-ku-01",
          "title": "网管对象",
          "kind": "concept",
          "shortText": "先识别网元、对象层级、权限和拓扑。",
          "narrationText": "网管入口不是菜单集合，而是网络对象管理模型，需理解 ManagedElement、小区、告警、PM 和 CM 的层级关系。"
        },
        {
          "id": "P07-ku-02",
          "title": "告警过滤",
          "kind": "concept",
          "shortText": "按级别、时间、对象和状态筛出有效告警。",
          "narrationText": "告警监控要过滤严重级别、发生时间、清除状态、关联对象和影响范围，优先处理影响业务的事件。"
        },
        {
          "id": "P07-ku-03",
          "title": "性能查询",
          "kind": "criteria",
          "shortText": "PM 指标按趋势、对比和忙时短板判读。",
          "narrationText": "性能查询关注趋势、忙时、同比和环比，不把瞬时值当作全局结论。"
        },
        {
          "id": "P07-ku-04",
          "title": "配置核查",
          "kind": "evidence",
          "shortText": "CM 数据对齐规划、版本和变更记录。",
          "narrationText": "配置核查要确认当前值、规划值、版本来源和变更记录，识别参数漂移和误配置风险。"
        },
        {
          "id": "P07-ku-05",
          "title": "权限边界",
          "kind": "practice",
          "shortText": "角色权限、操作范围和审计记录必须清晰。",
          "narrationText": "网管操作要明确角色权限和审计记录，查询、修改、派单和回退不能混用责任边界。"
        },
        {
          "id": "P07-ku-06",
          "title": "派单闭环",
          "kind": "review",
          "shortText": "监控发现转成可跟踪工单和复核结果。",
          "narrationText": "网管价值在于把发现、定位、派单、处理和复核连成闭环，形成可追踪的运维记录。"
        }
      ],
      "reviewSummary": "复盘时检查网元对象、告警状态、PM 趋势、CM 版本和审计记录是否一致，避免菜单操作脱离对象模型。"
    }
  },
